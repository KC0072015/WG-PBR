# Path on the NAS where your secret WireGuard configs are stored.
# This directory must contain: wg0-server.conf, surfshark.conf
# These files are NOT in Git — create them manually on the NAS once.
SECRETS_PATH=/opt/pbr-vpn-secrets

# UDP port exposed for WireGuard clients to connect
WG_PORT=51820

# VPN subnet assigned to WireGuard clients
WG_SERVER_SUBNET=10.8.0.0/24

# IP address of the WireGuard server inside the VPN
WG_SERVER_IP=10.8.0.1

# Internal DNS server IP (e.g. AdGuard Home, Pi-hole) used by dnsmasq as upstream
INTERNAL_DNS_IP=10.0.1.15
